# Port the HTTP + WebSocket server listens on (default: 3000)
PORT=3000

# Optional: enables the AI game analysis ("KI-Trainer") feature.
# Without a key the app still works — only the post-game Gemini analysis
# endpoint returns an error message.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: WebSocket heartbeat interval in milliseconds (default: 30000)
# HEARTBEAT_INTERVAL=30000
